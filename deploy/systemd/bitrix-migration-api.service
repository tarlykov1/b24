[Unit]
Description=Bitrix Migration API
After=network-online.target mysql.service
Wants=network-online.target

[Service]
Type=simple
User=bitrix-migration
Group=bitrix-migration
WorkingDirectory=/opt/bitrix-migration
Environment=MIGRATION_DATABASE_URL=mysql:host=127.0.0.1;dbname=bitrix_migration;charset=utf8mb4
ExecStart=/usr/bin/php -S 127.0.0.1:8088 -t apps/migration-module/ui/admin
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
