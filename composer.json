{
    "name": "migration/bitrix24-toolkit",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "ExportAgent\\": "apps/export-agent/src/",
            "MigrationModule\\": "apps/migration-module/src/"
        }
    },
    "scripts": {
        "test": "php tests/PrototypeTest.php && php tests/CliContractTest.php && php tests/OperationalApiTruthfulnessTest.php",
        "cli:help": "php bin/migration-module help",
        "cli:validate": "php bin/migration-module validate",
        "cli:dry-run": "php bin/migration-module dry-run",
        "cli:execute": "php bin/migration-module execute",
        "cli:resume": "php bin/migration-module resume",
        "cli:verify": "php bin/migration-module verify",
        "cli:report": "php bin/migration-module report"
    }
}
