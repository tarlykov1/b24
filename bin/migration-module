#!/usr/bin/env php
<?php

declare(strict_types=1);

use MigrationModule\Application\AuditDiscovery\AuditDiscoveryService;
use MigrationModule\Application\DeltaUpload\BaselineDeltaServices;
use MigrationModule\Application\Cutover\CutoverFinalizationRepository;
use MigrationModule\Application\Cutover\CutoverFinalizationService;
use MigrationModule\Application\Cutover\CutoverFinalizationStateMachine;
use MigrationModule\Application\Cutover\CutoverReadinessEvaluator;
use MigrationModule\Application\Cutover\CutoverVerificationRunner;
use MigrationModule\Application\Cutover\FinalDeltaCollector;
use MigrationModule\Application\Cutover\FreezeWindowManager;
use MigrationModule\Application\Cutover\GoLiveDecisionEngine;
use MigrationModule\Audit\ChangeVelocityAnalyzer;
use MigrationModule\Infrastructure\Bitrix\BitrixRestClient;
use MigrationModule\Preflight\CheckContext;
use MigrationModule\Preflight\CheckRegistry;
use MigrationModule\Preflight\PreflightRunner;
use MigrationModule\Prototype\Adapter\BitrixRestAdapter;
use MigrationModule\Prototype\Adapter\StubSourceAdapter;
use MigrationModule\Prototype\Adapter\StubTargetAdapter;
use MigrationModule\Prototype\ConfigLoader;
use MigrationModule\Prototype\Policy\IdConflictResolutionPolicy;
use MigrationModule\Prototype\Policy\UserHandlingPolicy;
use MigrationModule\Prototype\PrototypeRuntime;
use MigrationModule\Prototype\Storage\MySqlStorage;
use MigrationModule\Support\DbConfig;

require_once __DIR__ . '/../apps/migration-module/bootstrap.php';
migration_module_bootstrap(dirname(__DIR__));

function out(array $payload, int $code = 0): never
{
    echo json_encode($payload, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) . PHP_EOL;
    exit($code);
}

function parseArgs(array $argv): array
{
    $positionals = [];
    $options = [];
    foreach (array_slice($argv, 2) as $arg) {
        if (!str_starts_with((string) $arg, '--')) {
            $positionals[] = $arg;
            continue;
        }
        [$key, $value] = array_pad(explode('=', substr((string) $arg, 2), 2), 2, '1');
        $options[$key] = $value;
    }

    return ['options' => $options, 'positionals' => $positionals];
}

function recordsByAdapter(object $adapter, string $entityType, int $batch = 100): array
{
    if (!method_exists($adapter, 'fetch')) {
        return [];
    }

    $offset = 0;
    $rows = [];
    while (true) {
        $chunk = $adapter->fetch($entityType, $offset, $batch);
        if ($chunk === []) {
            break;
        }
        $rows = array_merge($rows, $chunk);
        $offset += count($chunk);
    }

    return $rows;
}

function tableExists(PDO $pdo, string $table): bool
{
    try {
        $stmt = $pdo->query('SELECT 1 FROM ' . $table . ' LIMIT 1');
        $stmt->fetch();
        return true;
    } catch (Throwable) {
        return false;
    }
}


function requiredOption(array $options, string $key, string $command): string
{
    $value = (string) ($options[$key] ?? '');
    if ($value === '') {
        throw new RuntimeException('missing_required_argument:' . $key . ':' . $command);
    }

    return $value;
}

/** @return array<string,mixed> */
function parseJsonOption(array $options, string $key, string $command): array
{
    if (!isset($options[$key])) {
        return [];
    }

    $decoded = json_decode((string) $options[$key], true);
    if (!is_array($decoded)) {
        throw new RuntimeException('invalid_json_argument:' . $key . ':' . $command);
    }

    return $decoded;
}

function cutoverError(Throwable $e, string $command): never
{
    $raw = $e->getMessage();
    $details = [];
    if (str_starts_with($raw, 'complete_gate_denied:')) {
        $json = substr($raw, strlen('complete_gate_denied:'));
        $decoded = json_decode($json, true);
        if (is_array($decoded)) {
            $details = $decoded;
        }
    }

    $code = $details['error_code'] ?? 'cutover_command_failed';
    if ($details === []) {
        if (str_starts_with($raw, 'missing_required_argument:')) {
            [, $argName] = array_pad(explode(':', $raw, 3), 3, '');
            $code = 'missing_required_argument';
            $details = ['error_code' => $code, 'argument' => $argName, 'next_action' => 'provide_' . $argName];
        } elseif (str_starts_with($raw, 'invalid_json_argument:')) {
            [, $argName] = array_pad(explode(':', $raw, 3), 3, '');
            $code = 'invalid_json_argument';
            $details = ['error_code' => $code, 'argument' => $argName, 'next_action' => 'fix_json_payload'];
        } elseif (str_starts_with($raw, 'freeze_session_not_found')) {
            $code = 'freeze_session_not_found';
            $details = ['error_code' => $code, 'next_action' => 'run_cutover_prepare'];
        } elseif (str_starts_with($raw, 'duplicate_prepare_conflict:')) {
            [, $state] = array_pad(explode(':', $raw, 2), 2, 'unknown');
            $code = 'duplicate_prepare_conflict';
            $details = ['error_code' => $code, 'current_state' => $state, 'next_action' => 'use_existing_session_or_abort'];
        } else {
            $details = ['error_code' => $code, 'message' => $raw];
        }
    }

    out(['ok' => false, 'command' => $command, 'error' => $details], 2);
}

function classifyMysqlBootstrapFailure(Throwable $e): string
{
    $message = strtolower($e->getMessage());

    return match (true) {
        str_contains($message, 'connection refused'), str_contains($message, 'no route to host'), str_contains($message, 'php_network_getaddresses') => 'mysql_connection_refused',
        str_contains($message, 'access denied') => 'mysql_auth_failure',
        str_contains($message, 'timeout') => 'mysql_timeout',
        str_contains($message, 'unknown database') => 'mysql_database_not_found',
        default => 'mysql_connection_or_permission_failed',
    };
}

function mysqlBootstrapFailure(Throwable $e, string $command, array $dbConfig): never
{
    out([
        'ok' => false,
        'command' => $command,
        'error' => [
            'error_code' => classifyMysqlBootstrapFailure($e),
            'message' => $e->getMessage(),
            'host' => (string) ($dbConfig['host'] ?? ''),
            'port' => (int) ($dbConfig['port'] ?? 0),
            'next_action' => 'run_deployment_check_and_fix_mysql_connectivity',
        ],
    ], 2);
}

function futureCommandResponse(string $command): never
{
    out([
        'ok' => false,
        'command' => $command,
        'message' => 'Command not available in current migration runtime. Reserved for future platform extensions.',
        'future' => true,
    ], 2);
}

$command = $argv[1] ?? 'help';
$parsed = parseArgs($argv);
$options = $parsed['options'];

$futureNamespaces = ['snapshot:', 'reconciliation:', 'conflicts:', 'watermarks:'];
if (in_array($command, ['snapshot', 'reconciliation', 'conflicts', 'watermarks'], true)) {
    futureCommandResponse($command);
}
foreach ($futureNamespaces as $ns) {
    if (str_starts_with($command, $ns)) {
        futureCommandResponse($command);
    }
}

$configPath = (string) ($options['config'] ?? 'migration.config.yml');
$config = (new ConfigLoader())->load($configPath);
$dbConfig = DbConfig::fromRuntimeSources((array) ($config['storage'] ?? []), dirname(__DIR__));

if ($command === 'deployment:check') {
    $result = (new \MigrationModule\Application\Readiness\SystemCheckService())->check($dbConfig);
    $exitCode = ($result['ok'] ?? false) ? 0 : 2;
    out($result + ['command' => 'deployment:check'], $exitCode);
}

try {
    $storage = new MySqlStorage(DbConfig::dsn($dbConfig), (string) $dbConfig['user'], (string) $dbConfig['password']);
    $storage->initSchema();
} catch (Throwable $e) {
    mysqlBootstrapFailure($e, $command, $dbConfig);
}

$sourceAdapter = new StubSourceAdapter();
$targetAdapter = new StubTargetAdapter();
if ((($_ENV['BITRIX_WEBHOOK_URL'] ?? getenv('BITRIX_WEBHOOK_URL') ?: '') !== '') && (($_ENV['BITRIX_WEBHOOK_TOKEN'] ?? getenv('BITRIX_WEBHOOK_TOKEN') ?: '') !== '')) {
    $client = new BitrixRestClient((string) ($_ENV['BITRIX_WEBHOOK_URL'] ?? getenv('BITRIX_WEBHOOK_URL')), (string) ($_ENV['BITRIX_WEBHOOK_TOKEN'] ?? getenv('BITRIX_WEBHOOK_TOKEN')));
    $restAdapter = new BitrixRestAdapter($client);
    $sourceAdapter = $restAdapter;
    $targetAdapter = $restAdapter;
}

$runtime = new PrototypeRuntime($storage, $sourceAdapter, $targetAdapter, new IdConflictResolutionPolicy(), new UserHandlingPolicy(), $config);
$uploadDelta = new BaselineDeltaServices($storage);
$cutoverFinalization = new CutoverFinalizationService(
    new CutoverFinalizationRepository($storage->pdo()),
    new CutoverFinalizationStateMachine(),
    new CutoverReadinessEvaluator(),
    new FreezeWindowManager(),
    new FinalDeltaCollector($storage),
    new CutoverVerificationRunner(),
    new GoLiveDecisionEngine(),
    $storage,
);
$jobId = (string) ($options['job-id'] ?? '');

if ($command === 'help') {
    out(['commands' => [
        'validate', 'config:validate', 'create-job', 'plan', 'plan:show', 'plan:export', 'dry-run', 'execute', 'resume', 'pause', 'retry', 'status', 'verify', 'report',
        'preflight', 'deployment:check',
        'audit:run', 'audit:summary', 'audit:report', 'audit:velocity',
        'target:inspect', 'target:cleanup-plan', 'target:cleanup-execute',
        'delta:plan', 'delta:execute',
        'baseline:index', 'baseline:status', 'baseline:verify', 'delta:scan', 'delta:resume', 'delta:report', 'delta:cutover-check',
        'verify:relations', 'verify:counts', 'verify:integrity', 'verify:files',
        'cutover:prepare','cutover:readiness','cutover:arm','cutover:freeze:start','cutover:freeze:status','cutover:delta:final','cutover:verify','cutover:verdict','cutover:abort','cutover:resume','cutover:complete',
    ]]);
}

$runPreflight = static function (bool $strictMode = false) use ($config, $sourceAdapter, $targetAdapter, $storage): array {
    $context = new CheckContext($config, $sourceAdapter, $targetAdapter, $storage->pdo());
    $report = (new PreflightRunner(new CheckRegistry(), $context))->run($strictMode);

    return $report->toArray() + ['exit_code' => $report->exitCode()];
};

if ($command === 'preflight') {
    $strictMode = isset($options['strict']);
    $report = $runPreflight($strictMode);
    $exit = (int) ($report['exit_code'] ?? 2);
    unset($report['exit_code']);
    out($report, $exit);
}


if (in_array($command, ['create-job', 'execute'], true)) {
    $strictMode = isset($options['strict']);
    $preflight = $runPreflight($strictMode);
    if (($preflight['status'] ?? 'blocked') === 'blocked') {
        unset($preflight['exit_code']);
        out([
            'error' => 'preflight_blocked',
            'message' => 'Migration action blocked by preflight safety validator.',
            'preflight' => $preflight,
        ], 2);
    }
}

if (in_array($command, ['validate', 'config:validate'], true)) {
    out($command === 'validate' ? $runtime->validate() : $runtime->configValidate(), $command === 'validate' ? 0 : (($runtime->configValidate()['ok'] ?? false) ? 0 : 2));
}

if ($command === 'create-job') {
    out(['job_id' => $storage->createJob((string) ($options['mode'] ?? 'initial'))]);
}

if ($jobId === '' && !in_array($command, ['help', 'validate', 'config:validate', 'create-job', 'deployment:check', 'audit:run', 'audit:summary', 'audit:report', 'audit:velocity', 'target:inspect', 'target:cleanup-plan', 'target:cleanup-execute','cutover:freeze:status','cutover:verdict','cutover:abort','cutover:resume','cutover:complete'], true)) {
    out(['error' => 'job_id_required', 'usage' => $command . ' --job-id=<id>'], 2);
}
if ($jobId !== '') {
    $storage->assertJobExists($jobId);
}

try {
switch ($command) {
    case 'plan':
        out($runtime->plan($jobId));
    case 'plan:show':
        out($runtime->showPlan($jobId));
    case 'plan:export':
        out($runtime->exportPlan($jobId, (string) ($options['output'] ?? 'reports/plan-' . $jobId . '.json')));
    case 'dry-run':
        out($runtime->dryRun($jobId));
    case 'execute':
        out($runtime->execute($jobId));
    case 'resume':
        out($runtime->execute($jobId, true));
    case 'pause':
        $storage->setJobStatus($jobId, 'paused');
        out(['job_id' => $jobId, 'status' => 'paused']);
    case 'retry':
        $storage->setJobStatus($jobId, 'running');
        out(['job_id' => $jobId, 'status' => 'running', 'retry' => true]);
    case 'status':
        out(['job_id' => $jobId, 'status' => $storage->jobStatus($jobId), 'summary' => $storage->summary($jobId), 'delta' => $storage->deltaStatus($jobId)]);
    case 'verify':
        out($runtime->verify($jobId));
    case 'report':
        $report = ['job_id' => $jobId, 'status' => $storage->jobStatus($jobId), 'summary' => $storage->summary($jobId), 'delta' => $storage->deltaStatus($jobId), 'generated_at' => date(DATE_ATOM)];
        if (!is_dir('reports')) {
            mkdir('reports', 0777, true);
        }
        file_put_contents('reports/migration_report.json', (string) json_encode($report, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES));
        out($report);
    case 'audit:run':
    case 'audit:summary':
    case 'audit:report':
        $kind = str_replace('audit:', '', $command);
        out((new AuditDiscoveryService())->run($kind, isset($options['deep'])));
    case 'audit:velocity':
        $auditDb = DbConfig::fromRuntimeSources([], dirname(__DIR__));
        $pdo = null;
        if ($auditDb['name'] !== '' && $auditDb['user'] !== '') {
            $pdo = new PDO(DbConfig::dsn($auditDb), (string) $auditDb['user'], (string) $auditDb['password'], [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]);
        }
        $rest = null;
        if ((($_ENV['BITRIX_WEBHOOK_URL'] ?? getenv('BITRIX_WEBHOOK_URL') ?: '') !== '') && (($_ENV['BITRIX_WEBHOOK_TOKEN'] ?? getenv('BITRIX_WEBHOOK_TOKEN') ?: '') !== '')) {
            $rest = new BitrixRestClient((string) ($_ENV['BITRIX_WEBHOOK_URL'] ?? getenv('BITRIX_WEBHOOK_URL')), (string) ($_ENV['BITRIX_WEBHOOK_TOKEN'] ?? getenv('BITRIX_WEBHOOK_TOKEN')));
        }
        out((new ChangeVelocityAnalyzer())->analyze($pdo, $rest, (string) ($_ENV['BITRIX_UPLOAD_PATH'] ?? getenv('BITRIX_UPLOAD_PATH') ?: '/upload')));
    case 'target:inspect':
    case 'target:cleanup-plan':
    case 'target:cleanup-execute':
        $targets = [
            'contacts' => 'crm.contact',
            'deals' => 'crm.deal',
            'tasks' => 'tasks.task',
        ];
        $plan = ['delete' => [], 'preserve' => ['administrators', 'system users', 'configuration entities'], 'note' => 'Infrastructure configuration is never touched.'];
        foreach ($targets as $label => $entityType) {
            $rows = recordsByAdapter($targetAdapter, $entityType, 50);
            foreach ($rows as $row) {
                $name = strtolower((string) ($row['TITLE'] ?? $row['title'] ?? $row['NAME'] ?? $row['name'] ?? ''));
                $isTest = str_contains($name, 'test') || str_contains($name, 'demo') || str_contains($name, 'sample');
                if ($isTest) {
                    $plan['delete'][] = ['entity' => $label, 'id' => (string) ($row['ID'] ?? $row['id'] ?? ''), 'name' => $name];
                }
            }
        }
        if ($command === 'target:cleanup-execute') {
            out(['plan' => $plan, 'executed' => false, 'message' => 'Execution is metadata-only in current runtime. Apply cleanup manually or via dedicated destructive adapter.']);
        }
        out(['plan' => $plan, 'mode' => $command === 'target:inspect' ? 'inspect' : 'plan']);
    case 'cutover:prepare':
        $freezeId = (string) ($options['freeze-id'] ?? ('freeze_' . bin2hex(random_bytes(4))));
        requiredOption($options, 'job-id', 'cutover:prepare');
        $meta = parseJsonOption($options, 'meta-json', 'cutover:prepare');
        out($cutoverFinalization->prepare($freezeId, $jobId, (string) ($options['source-instance-id'] ?? 'source-prod'), (string) ($options['target-instance-id'] ?? 'target-clean'), (string) ($options['actor'] ?? 'operator'), $meta));
    case 'cutover:readiness':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:readiness');
        $signals = parseJsonOption($options, 'signals-json', 'cutover:readiness');
        out($cutoverFinalization->readiness($freezeId, $signals));
    case 'cutover:arm':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:arm');
        $domains = isset($options['protected-domains']) ? array_values(array_filter(explode(',', (string) $options['protected-domains']))) : ['users', 'tasks', 'crm', 'comments', 'files', 'permissions', 'custom_fields'];
        out($cutoverFinalization->arm($freezeId, (string) ($options['actor'] ?? 'operator'), (string) ($options['mode'] ?? 'advisory_freeze'), $domains));
    case 'cutover:freeze:start':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:freeze:start');
        $domains = isset($options['protected-domains']) ? array_values(array_filter(explode(',', (string) $options['protected-domains']))) : ['users', 'tasks', 'crm', 'comments', 'files', 'permissions', 'custom_fields'];
        $mutations = parseJsonOption($options, 'mutations-json', 'cutover:freeze:start');
        out($cutoverFinalization->freezeStart($freezeId, (string) ($options['actor'] ?? 'operator'), (string) ($options['mode'] ?? 'advisory_freeze'), $domains, $mutations));
    case 'cutover:freeze:status':
        out($cutoverFinalization->status(requiredOption($options, 'freeze-id', 'cutover:freeze:status')));
    case 'cutover:delta:final':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:delta:final');
        $baseline = parseJsonOption($options, 'baseline-json', 'cutover:delta:final');
        out($cutoverFinalization->finalDelta($freezeId, (string) ($options['actor'] ?? 'operator'), $baseline));
    case 'cutover:verify':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:verify');
        $signals = parseJsonOption($options, 'signals-json', 'cutover:verify');
        out($cutoverFinalization->verify($freezeId, (string) ($options['actor'] ?? 'operator'), $signals));
    case 'cutover:verdict':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:verdict');
        $ctx = parseJsonOption($options, 'context-json', 'cutover:verdict');
        out($cutoverFinalization->verdict($freezeId, $ctx));
    case 'cutover:abort':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:abort');
        out($cutoverFinalization->abort($freezeId, (string) ($options['actor'] ?? 'operator'), (string) ($options['reason'] ?? 'operator_abort')));
    case 'cutover:resume':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:resume');
        out($cutoverFinalization->resume($freezeId, (string) ($options['actor'] ?? 'operator')));
    case 'cutover:complete':
        $freezeId = requiredOption($options, 'freeze-id', 'cutover:complete');
        $override = (($options['override'] ?? '0') === '1');
        $payload = parseJsonOption($options, 'override-json', 'cutover:complete');
        out($cutoverFinalization->complete($freezeId, (string) ($options['actor'] ?? 'operator'), $override, $payload));

    case 'delta:plan':
        if (isset($options['scan-id'])) {
            out($uploadDelta->buildTransferPlan($jobId, (string) $options['scan-id'], (string) ($options['policy'] ?? 'balanced')));
        }
        $scanId = 'delta_' . bin2hex(random_bytes(4));
        $changed = [];
        foreach ($sourceAdapter->entityTypes() as $entityType) {
            $sourceRows = recordsByAdapter($sourceAdapter, $entityType, 100);
            foreach ($sourceRows as $row) {
                $entityId = (string) ($row['id'] ?? $row['ID'] ?? '');
                if ($entityId === '') {
                    continue;
                }
                $fingerprint = hash('sha256', json_encode($row, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES));
                $existing = $storage->deltaStates($jobId, $entityType);
                $known = null;
                foreach ($existing as $state) {
                    if ((string) $state['entity_id'] === $entityId) {
                        $known = $state;
                        break;
                    }
                }
                if ($known === null || (string) ($known['fingerprint'] ?? '') !== $fingerprint) {
                    $storage->saveDeltaChange($jobId, $scanId, 'incremental', $entityType, $entityId, $known === null ? 'create' : 'update', $fingerprint, $row);
                    $changed[] = ['entity_type' => $entityType, 'entity_id' => $entityId, 'action' => $known === null ? 'create' : 'update'];
                }
                $storage->upsertDeltaState($jobId, $entityType, $entityId, $fingerprint, null, (string) ($row['updated_at'] ?? null), 0);
            }
            $storage->saveDeltaCursor($jobId, $entityType, date(DATE_ATOM), null, null, 'incremental');
        }
        out(['job_id' => $jobId, 'scan_id' => $scanId, 'changes' => $changed, 'change_count' => count($changed)]);
    case 'delta:execute':
        if (isset($options['plan-id'])) {
            $sourceRoot = (string) ($options['source-root'] ?? ($_ENV['BITRIX_UPLOAD_PATH'] ?? getenv('BITRIX_UPLOAD_PATH') ?: '/upload/source'));
            $targetRoot = (string) ($options['target-root'] ?? ($_ENV['BITRIX_TARGET_UPLOAD_PATH'] ?? getenv('BITRIX_TARGET_UPLOAD_PATH') ?: '/upload/target'));
            out($uploadDelta->executeTransferPlan((string) $options['plan-id'], $sourceRoot, $targetRoot, isset($options['dry-run']), (int) ($options['limit'] ?? 1000)));
        }
        $changes = $storage->pendingDeltaChanges($jobId);
        $applied = 0;
        foreach ($changes as $change) {
            $payload = json_decode((string) ($change['payload'] ?? '{}'), true);
            if (is_array($payload)) {
                $targetAdapter->apply((string) $change['entity_type'], $payload);
            }
            $storage->markDeltaChangeApplied((int) $change['id']);
            $applied++;
        }
        out(['job_id' => $jobId, 'applied' => $applied, 'status' => $storage->deltaStatus($jobId)]);

    case 'baseline:index':
        $sourceRoot = (string) ($options['source-root'] ?? ($_ENV['BITRIX_UPLOAD_PATH'] ?? getenv('BITRIX_UPLOAD_PATH') ?: '/upload/source'));
        $targetRoot = (string) ($options['target-root'] ?? ($_ENV['BITRIX_TARGET_UPLOAD_PATH'] ?? getenv('BITRIX_TARGET_UPLOAD_PATH') ?: '/upload/target'));
        $mode = (string) ($options['verification-mode'] ?? 'fast');
        out($uploadDelta->baselineIndex($jobId, $sourceRoot, $targetRoot, (int) ($options['chunk-size'] ?? 500), $mode));
    case 'baseline:status':
        $baselineId = (string) ($options['baseline-id'] ?? '');
        out(['baseline' => $baselineId === '' ? null : $storage->baselineSnapshot($baselineId)]);
    case 'baseline:verify':
        $baselineId = (string) ($options['baseline-id'] ?? '');
        $base = $baselineId === '' ? null : $storage->baselineSnapshot($baselineId);
        out(['baseline_id' => $baselineId, 'status' => $base['status'] ?? 'missing', 'indexed_files' => $base['indexed_files'] ?? 0]);
    case 'delta:scan':
        $baselineId = (string) ($options['baseline-id'] ?? '');
        if ($baselineId === '') {
            out(['error' => 'baseline_id_required'], 2);
        }
        $refs = [];
        if (isset($options['refs-json']) && is_file((string) $options['refs-json'])) {
            $refs = json_decode((string) file_get_contents((string) $options['refs-json']), true) ?: [];
        }
        $refPaths = [];
        foreach ($refs as $r) {
            if (is_array($r) && isset($r['path'])) {
                $refPaths[] = (string) $r['path'];
            }
        }
        $sourceRoot = (string) ($options['source-root'] ?? ($_ENV['BITRIX_UPLOAD_PATH'] ?? getenv('BITRIX_UPLOAD_PATH') ?: '/upload/source'));
        $targetRoot = (string) ($options['target-root'] ?? ($_ENV['BITRIX_TARGET_UPLOAD_PATH'] ?? getenv('BITRIX_TARGET_UPLOAD_PATH') ?: '/upload/target'));
        out($uploadDelta->deltaScan($jobId, $baselineId, $sourceRoot, $targetRoot, $refPaths));
    case 'delta:resume':
        $planId = (string) ($options['plan-id'] ?? '');
        if ($planId === '') {
            out(['error' => 'plan_id_required'], 2);
        }
        $sourceRoot = (string) ($options['source-root'] ?? ($_ENV['BITRIX_UPLOAD_PATH'] ?? getenv('BITRIX_UPLOAD_PATH') ?: '/upload/source'));
        $targetRoot = (string) ($options['target-root'] ?? ($_ENV['BITRIX_TARGET_UPLOAD_PATH'] ?? getenv('BITRIX_TARGET_UPLOAD_PATH') ?: '/upload/target'));
        out($uploadDelta->executeTransferPlan($planId, $sourceRoot, $targetRoot, isset($options['dry-run']), (int) ($options['limit'] ?? 1000)));
    case 'delta:report':
        $scanId = (string) ($options['scan-id'] ?? '');
        if ($scanId === '') {
            out(['error' => 'scan_id_required'], 2);
        }
        $counts = $storage->deltaScanCounts($scanId);
        $issues = $storage->reconciliationIssuesByScan($scanId);
        out(['scan_id' => $scanId, 'counts' => $counts, 'issues' => $issues]);
    case 'delta:cutover-check':
        $scanId = (string) ($options['scan-id'] ?? '');
        if ($scanId === '') {
            out(['error' => 'scan_id_required'], 2);
        }
        out($uploadDelta->cutoverCheck($jobId, $scanId, (int) ($options['pass'] ?? 1)));
    case 'verify:counts':
        out(['job_id' => $jobId, 'counts' => $storage->summary($jobId)]);
    case 'verify:relations':
    case 'verify:integrity':
        $issues = [];
        $tasks = recordsByAdapter($sourceAdapter, 'tasks.task', 100);
        foreach ($tasks as $task) {
            if ((string) ($task['responsible_id'] ?? '') === '') {
                $issues[] = ['type' => 'task->user', 'entity_id' => (string) ($task['id'] ?? ''), 'issue' => 'missing_responsible'];
            }
        }
        $deals = recordsByAdapter($sourceAdapter, 'crm.deal', 100);
        foreach ($deals as $deal) {
            if ((string) ($deal['COMPANY_ID'] ?? $deal['company_id'] ?? '') === '' && (string) ($deal['CONTACT_ID'] ?? $deal['contact_id'] ?? '') === '') {
                $issues[] = ['type' => 'deal->company/contact', 'entity_id' => (string) ($deal['ID'] ?? $deal['id'] ?? ''), 'issue' => 'missing_link'];
            }
        }
        $comments = recordsByAdapter($sourceAdapter, 'task.comments', 100);
        foreach ($comments as $comment) {
            if ((string) ($comment['TASK_ID'] ?? $comment['entity_id'] ?? '') === '') {
                $issues[] = ['type' => 'comment->entity', 'entity_id' => (string) ($comment['ID'] ?? $comment['id'] ?? ''), 'issue' => 'orphan'];
            }
        }
        out(['job_id' => $jobId, 'status' => $issues === [] ? 'ok' : 'issues_found', 'issues' => $issues]);
    case 'verify:files':
        $files = recordsByAdapter($sourceAdapter, 'files', 100);
        $issues = [];
        foreach ($files as $file) {
            $path = (string) ($file['PATH'] ?? $file['path'] ?? '');
            if ($path === '') {
                $issues[] = ['type' => 'missing_file_path', 'entity_id' => (string) ($file['ID'] ?? $file['id'] ?? ''), 'scope' => 'reference_verification'];
            }
        }
        out(['job_id' => $jobId, 'checked' => count($files), 'issues' => $issues, 'bulk_transfer' => 'out_of_scope']);
    default:
        if (in_array($command, ['upgrade:check', 'upgrade:install', 'upgrade:rollback', 'reconciliation:run', 'baseline:plan'], true)) {
            futureCommandResponse($command);
        }
        out(['error' => 'unknown_command', 'command' => $command], 2);
}
} catch (Throwable $e) {
    if (str_starts_with($command, 'cutover:')) {
        cutoverError($e, $command);
    }

    out(['ok' => false, 'command' => $command, 'error' => $e->getMessage()], 2);
}
