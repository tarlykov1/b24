#!/usr/bin/env php
<?php

declare(strict_types=1);

use MigrationModule\Application\AuditDiscovery\AuditDiscoveryService;
use MigrationModule\Application\AuditDiscovery\SourceAuditEngine;
use MigrationModule\Audit\ChangeVelocityAnalyzer;
use MigrationModule\Application\Readiness\SystemCheckService;
use MigrationModule\Application\Execution\DistributedWorkerControlPlane;
use MigrationModule\Application\Throttling\AdaptiveRateLimiter;
use MigrationModule\Application\GoLive\CommunicationTemplateEngine;
use MigrationModule\Application\GoLive\CutoverAuditTrail;
use MigrationModule\Application\GoLive\CutoverPlanService;
use MigrationModule\Application\GoLive\CutoverRehearsalEngine;
use MigrationModule\Application\GoLive\FinalDeltaSyncOrchestrator;
use MigrationModule\Application\GoLive\FreezePolicyManager;
use MigrationModule\Application\GoLive\GoLiveOrchestrator;
use MigrationModule\Application\GoLive\GoLiveReadinessEngine;
use MigrationModule\Application\GoLive\GoLiveStateMachine;
use MigrationModule\Application\GoLive\PreflightCheckRunner;
use MigrationModule\Application\GoLive\RollbackCoordinator;
use MigrationModule\Application\GoLive\RunbookGenerator;
use MigrationModule\Application\GoLive\SmokeTestRunner;
use MigrationModule\Application\GoLive\WindowRecommendationService;
use MigrationModule\ControlCenter\Controller\JobController;
use MigrationModule\ControlCenter\Service\DiffEngine;
use MigrationModule\Infrastructure\Bitrix\BitrixRestClient;
use MigrationModule\Prototype\Adapter\BitrixRestAdapter;
use MigrationModule\Prototype\Adapter\StubSourceAdapter;
use MigrationModule\Prototype\Adapter\StubTargetAdapter;
use MigrationModule\Prototype\ConfigLoader;
use MigrationModule\Prototype\Policy\IdConflictResolutionPolicy;
use MigrationModule\Prototype\Policy\UserHandlingPolicy;
use MigrationModule\Prototype\PrototypeRuntime;
use MigrationModule\Prototype\Storage\SqliteStorage;
use MigrationModule\Simulation\Application\FailureSimulationService;
use MigrationModule\Simulation\Application\SimulationEngine;
use MigrationModule\Simulation\Domain\SimulationInput;
use MigrationModule\Simulation\Estimator\CRMEstimator;
use MigrationModule\Simulation\Estimator\FilesEstimator;
use MigrationModule\Simulation\Estimator\TasksEstimator;
use MigrationModule\Simulation\Estimator\UsersEstimator;
use MigrationModule\Simulation\Infrastructure\SimulationRepository;
use MigrationModule\Simulation\Report\SimulationReportBuilder;
use MigrationModule\Simulation\Scenario\ScenarioBuilder;

$autoload = __DIR__ . '/../vendor/autoload.php';
if (is_file($autoload)) {
    require_once $autoload;
} else {
    spl_autoload_register(static function (string $class): void {
        $prefix = 'MigrationModule\\';
        if (!str_starts_with($class, $prefix)) {
            return;
        }

        $relative = substr($class, strlen($prefix));
        $path = __DIR__ . '/../apps/migration-module/src/' . str_replace('\\', '/', $relative) . '.php';
        if (is_file($path)) {
            require_once $path;
        }
    });
}

function out(array $payload, int $code = 0): never {
    echo json_encode($payload, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . PHP_EOL;
    exit($code);
}

$command = $argv[1] ?? 'help';
$configPath = str_starts_with($command, 'migration:workers:')
    ? 'migration.config.yml'
    : ($command === 'migration' ? ($argv[5] ?? 'migration.config.yml') : ($argv[2] ?? 'migration.config.yml'));

$audits = [
    'audit:portal' => 'portal',
    'audit:users' => 'users',
    'audit:tasks' => 'tasks',
    'audit:files' => 'files',
    'audit:crm' => 'crm',
    'audit:permissions' => 'permissions',
    'audit:linkage' => 'linkage',
    'audit:summary' => 'summary',
    'audit:report' => 'report',
    'audit:run' => 'run',
];
if (isset($audits[$command])) {
    $deep = in_array('--deep', $argv, true);
    out((new AuditDiscoveryService())->run($audits[$command], $deep));
}

if ($command === 'audit:velocity') {
    $opts = ['days' => 30, 'sample-size' => 1000, 'entity' => null, 'output' => 'json'];
    foreach (array_slice($argv, 2) as $arg) {
        if (!str_starts_with($arg, '--')) {
            continue;
        }

        [$key, $value] = array_pad(explode('=', substr($arg, 2), 2), 2, '');
        if ($key === 'days') {
            $opts['days'] = max(1, (int) $value);
        }
        if ($key === 'sample-size') {
            $opts['sample-size'] = max(50, (int) $value);
        }
        if ($key === 'entity' && $value !== '') {
            $opts['entity'] = $value;
        }
        if ($key === 'output' && $value !== '') {
            $opts['output'] = $value;
        }
    }

    $dsn = (string) ($_ENV['BITRIX_DB_DSN'] ?? getenv('BITRIX_DB_DSN') ?: '');
    $pdo = null;
    if ($dsn !== '') {
        $pdo = new PDO($dsn, (string) ($_ENV['BITRIX_DB_USER'] ?? getenv('BITRIX_DB_USER') ?: ''), (string) ($_ENV['BITRIX_DB_PASSWORD'] ?? getenv('BITRIX_DB_PASSWORD') ?: ''), [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]);
        if (str_starts_with($dsn, 'mysql:')) {
            $pdo->exec('SET SESSION TRANSACTION READ ONLY');
        }
    }

    $rest = null;
    if ((($_ENV['BITRIX_WEBHOOK_URL'] ?? getenv('BITRIX_WEBHOOK_URL') ?: '') !== '') && (($_ENV['BITRIX_WEBHOOK_TOKEN'] ?? getenv('BITRIX_WEBHOOK_TOKEN') ?: '') !== '')) {
        $rest = new BitrixRestClient((string) ($_ENV['BITRIX_WEBHOOK_URL'] ?? getenv('BITRIX_WEBHOOK_URL')), (string) ($_ENV['BITRIX_WEBHOOK_TOKEN'] ?? getenv('BITRIX_WEBHOOK_TOKEN')));
    }

    $upload = (string) ($_ENV['BITRIX_UPLOAD_PATH'] ?? getenv('BITRIX_UPLOAD_PATH') ?: '/upload');
    $report = (new ChangeVelocityAnalyzer())->analyze($pdo, $rest, $upload, (int) $opts['days'], (int) $opts['sample-size'], is_string($opts['entity']) ? $opts['entity'] : null);

    out($opts['output'] === 'json' ? $report : ['status' => 'ok', 'report' => 'reports/change_velocity_report.json']);
}

try {
    $config = (new ConfigLoader())->load($configPath);
    $storagePath = (string) (($config['storage']['path'] ?? '.prototype/migration.sqlite'));
    $storage = new SqliteStorage($storagePath);

    $sourceAdapter = new StubSourceAdapter();
    $targetAdapter = new StubTargetAdapter();
    if ((($_ENV['BITRIX_WEBHOOK_URL'] ?? '') !== '') && (($_ENV['BITRIX_WEBHOOK_TOKEN'] ?? '') !== '')) {
        $client = new BitrixRestClient((string) $_ENV['BITRIX_WEBHOOK_URL'], (string) $_ENV['BITRIX_WEBHOOK_TOKEN']);
        $restAdapter = new BitrixRestAdapter($client);
        $sourceAdapter = $restAdapter;
        $targetAdapter = $restAdapter;
    }

    $runtime = new PrototypeRuntime(
        $storage,
        $sourceAdapter,
        $targetAdapter,
        new IdConflictResolutionPolicy(),
        new UserHandlingPolicy(),
        $config,
    );

    if ($command === 'help') {
        out(['commands' => ['validate', 'plan', 'dry-run', 'execute', 'pause', 'resume', 'verify', 'verify-only', 'report', 'status', 'system:check', 'audit:portal', 'audit:users', 'audit:tasks', 'audit:files', 'audit:crm', 'audit:permissions', 'audit:summary', 'audit:report', 'audit:run', 'audit:velocity --days=30 --sample-size=1000 --entity=tasks --output=json', 'migration audit:source [--deep]', 'simulate', 'simulate:compare', 'simulate:scenario', 'simulate:capacity', 'simulate:failures', 'simulate:report', 'migration pause', 'migration resume', 'migration retry <entity_type>:<source_id>', 'migration repair', 'migration diff <entity_type>:<source_id>', 'migration delta:scan <job_id> [entity_type|all] [--phase=initial_bulk|incremental|pre_cutover|final_cutover]', 'migration delta:apply <job_id> [scan_id]', 'migration delta:status <job_id>', 'migration:hypercare:start', 'migration:hypercare:scan', 'migration:hypercare:reconcile', 'migration:hypercare:report', 'migration:hypercare:archive', 'migration:workers:init <job_id> <queue_csv> <workers_csv>', 'migration:workers:status <job_id>', 'migration:workers:pause <job_id> [reason]', 'migration:workers:resume <job_id>', 'migration:workers:retry <job_id> <queue_name>', 'migration:workers:heartbeat <job_id> <worker_id> <ok|fail> [status_code]']]);
    }

    if ($command === 'validate') {
        out($runtime->validate());
    }

    $storage->initSchema();

    if (str_starts_with($command, 'cutover:')) {
        $goLivePlan = new CutoverPlanService();
        $readiness = new GoLiveReadinessEngine();
        $freeze = new FreezePolicyManager();
        $delta = new FinalDeltaSyncOrchestrator();
        $rehearsal = new CutoverRehearsalEngine();
        $preflight = new PreflightCheckRunner();
        $stateMachine = new GoLiveStateMachine();
        $smoke = new SmokeTestRunner();
        $rollback = new RollbackCoordinator();
        $runbook = new RunbookGenerator();
        $comm = new CommunicationTemplateEngine();
        $window = new WindowRecommendationService();
        $audit = new CutoverAuditTrail();

        if ($command === 'cutover:plan') {
            $payload = [
                'environmentPair' => ['source' => 'bitrix24-prod', 'target' => 'bitrix24-new'],
                'migrationScope' => ['job' => 'wave-3', 'strategy' => 'department-by-department'],
                'window' => ['start' => '2026-04-19T22:00:00+03:00', 'freezeStart' => '2026-04-19T21:40:00+03:00'],
                'businessConstraints' => ['maxAllowedDowntimeMin' => 45, 'mustKeepOnline' => ['telephony']],
                'operatorRoles' => ['approver', 'migration_operator', 'infra_operator', 'business_owner', 'rollback_approver'],
                'readinessThresholds' => ['minScore' => 75],
                'communicationChecklist' => ['T-7 days', 'T-1 day', 'freeze-start'],
            ];
            out($goLivePlan->create('cp-default', $payload, 'cli-operator'));
        }

        if ($command === 'cutover:readiness') {
            out($readiness->assess([
                'completedMigrationWaves' => 3,
                'requiredMigrationWaves' => 3,
                'remainingQueueSize' => 82,
                'unresolvedIntegrityIssues' => 1,
                'unresolvedMappingConflicts' => 0,
                'workerHealth' => 0.91,
                'lastDryRunOk' => true,
                'lastVerificationOk' => true,
                'deltaSyncDurationEstimateMin' => 30,
                'maxAllowedDowntimeMin' => 45,
                'sourceLoadEstimate' => 0.66,
                'sourceLoadThreshold' => 0.75,
            ]));
        }

        if ($command === 'cutover:preflight') {
            out($preflight->evaluate([
                ['name' => 'source_reachable', 'severity' => 'critical', 'result' => true, 'message' => 'ok'],
                ['name' => 'target_reachable', 'severity' => 'critical', 'result' => true, 'message' => 'ok'],
                ['name' => 'backup_confirmed', 'severity' => 'critical', 'result' => true, 'message' => 'ok'],
                ['name' => 'source_activity_below_threshold', 'severity' => 'warning', 'result' => false, 'message' => 'high but understood'],
            ]));
        }

        if ($command === 'cutover:delta') {
            out($delta->run('dry_run_delta_estimation', [
                'sourceQpsLimit' => 60,
                'workerCount' => 10,
                'changes' => [
                    ['entityFamily' => 'users', 'count' => 120, 'created' => 4, 'updated' => 116],
                    ['entityFamily' => 'crm', 'count' => 420, 'created' => 33, 'updated' => 370, 'deleted' => 17],
                    ['entityFamily' => 'files', 'count' => 150, 'updated' => 120, 'archived' => 30],
                ],
            ]));
        }

        if ($command === 'cutover:rehearsal') {
            out($rehearsal->simulate(['entityVolume' => 55000, 'avgWorkerThroughput' => 170, 'workers' => 12, 'errorRate' => 0.03, 'dependencyPenalty' => 1.2, 'windowHours' => 6]));
        }

        if ($command === 'cutover:runbook') {
            out($runbook->generate(['currentVersion' => 3, 'goal' => 'Weekend production cutover', 'scope' => ['crm', 'tasks', 'files'], 'operatorRoles' => ['approver', 'migration_operator', 'infra_operator']]));
        }

        if ($command === 'cutover:state-graph') {
            out($stateMachine->graph());
        }

        if ($command === 'cutover:comm') {
            out(['message' => $comm->render('go_live_started', ['window' => '22:00-02:00', 'expected_downtime' => '45m', 'affected_modules' => 'CRM, Tasks', 'support_contact' => 'ops@example.com', 'business_owner' => 'Sales Ops Lead', 'next_update_time' => '22:30'])]);
        }

        if ($command === 'cutover:window') {
            out($window->recommend([
                ['day' => 'Fri', 'hour' => 23, 'activity' => 22],
                ['day' => 'Sat', 'hour' => 1, 'activity' => 7],
                ['day' => 'Sat', 'hour' => 3, 'activity' => 5],
                ['day' => 'Sun', 'hour' => 2, 'activity' => 4],
                ['day' => 'Mon', 'hour' => 10, 'activity' => 88],
            ], 35, 50));
        }

        if ($command === 'cutover:orchestrate') {
            $orch = new GoLiveOrchestrator($stateMachine, $readiness, $preflight, $delta, $smoke, $rollback, $audit);
            out($orch->run('cli-operator', ['completedMigrationWaves' => 3, 'requiredMigrationWaves' => 3, 'workerHealth' => 0.93, 'lastDryRunOk' => true, 'lastVerificationOk' => true], [
                ['name' => 'source_reachable', 'severity' => 'critical', 'result' => true, 'message' => 'ok'],
                ['name' => 'backup_confirmed', 'severity' => 'critical', 'result' => true, 'message' => 'ok'],
            ], [
                'sourceQpsLimit' => 55,
                'workerCount' => 10,
                'targetWritesAfterSwitch' => 1300,
                'changes' => [['entityFamily' => 'users', 'count' => 30, 'updated' => 30], ['entityFamily' => 'crm', 'count' => 90, 'created' => 10, 'updated' => 80]],
            ], [
                ['name' => 'login', 'severity' => 'critical', 'pass' => true],
                ['name' => 'crm_open', 'severity' => 'major', 'pass' => true],
                ['name' => 'files_open', 'severity' => 'minor', 'pass' => false],
            ]));
        }
    }

    if (str_starts_with($command, 'simulate')) {
        $input = new SimulationInput(
            entityVolumes: [
                'users' => (int) ($config['entities']['users'] ?? 1000),
                'deals' => (int) ($config['entities']['deals'] ?? 5000),
                'tasks' => (int) ($config['entities']['tasks'] ?? 12000),
                'files' => (int) ($config['entities']['files'] ?? 24000),
            ],
            audit: [
                'custom_fields' => (int) ($config['audit']['custom_fields'] ?? 140),
                'large_file_ratio' => (float) ($config['audit']['large_file_ratio'] ?? 0.2),
            ],
            dependencyGraph: [
                'deals' => ['users', 'companies'],
                'tasks' => ['users', 'groups'],
                'files' => ['tasks'],
            ],
            capabilities: [
                'source_safe_read_qps' => (int) ($config['safety']['source_read_qps'] ?? 90),
            ],
            policies: $config['policy'] ?? [],
        );

        $builder = new ScenarioBuilder();
        $engine = new SimulationEngine([new UsersEstimator(), new CRMEstimator(), new TasksEstimator(), new FilesEstimator()]);
        $reportBuilder = new SimulationReportBuilder();
        $simulationRepo = new SimulationRepository($storage->pdo());

        if ($command === 'simulate') {
            $scenario = $builder->buildCandidates($input)[1];
            $run = $engine->run($input, $scenario);
            $simulationRepo->saveScenario('audit_current', 'v1', $scenario, ['entity_volumes' => $input->entityVolumes, 'audit' => $input->audit]);
            $simulationRepo->saveRun($run);
            out(['summary' => $reportBuilder->toJson($run), 'text' => $reportBuilder->toMarkdown($run)]);
        }

        if ($command === 'simulate:compare') {
            $comparison = $engine->compare($input, array_slice($builder->buildCandidates($input), 0, 3));
            $simulationRepo->saveComparison('default_compare', $comparison->toArray());
            out($comparison->toArray());
        }

        if ($command === 'simulate:scenario') {
            $scenario = $builder->custom('Custom', 'full initial migration', ['worker_count' => (int) ($argv[3] ?? 8), 'window_hours' => (float) ($argv[4] ?? 8.0)]);
            $run = $engine->run($input, $scenario);
            out($reportBuilder->toJson($run));
        }

        if ($command === 'simulate:capacity') {
            $scenario = $builder->buildCandidates($input)[0];
            $run = $engine->run($input, $scenario);
            out(['source' => $run->sourceLoadProfile, 'target' => $run->targetLoadProfile, 'window_hours' => $scenario->parameters['window_hours']]);
        }

        if ($command === 'simulate:failures') {
            $scenario = $builder->buildCandidates($input)[1];
            $run = $engine->run($input, $scenario);
            $withFailures = (new FailureSimulationService())->apply($run->toArray(), ['network_instability', 'worker_crash']);
            out($withFailures);
        }

        if ($command === 'simulate:report') {
            $scenario = $builder->buildCandidates($input)[0];
            $run = $engine->run($input, $scenario);
            out(['json' => $reportBuilder->toJson($run), 'markdown' => $reportBuilder->toMarkdown($run)]);
        }
    }

    if (str_starts_with($command, 'migration:workers:')) {
        $limiter = new AdaptiveRateLimiter((string) ($config['throttling']['profile'] ?? 'safe'));
        $controlPlane = new DistributedWorkerControlPlane($storage, $limiter);
        $workerJobId = $argv[2] ?? 'job-workers-default';

        switch ($command) {
            case 'migration:workers:init':
                $queues = array_values(array_filter(array_map('trim', explode(',', (string) ($argv[3] ?? 'users,tasks,crm,files')))));
                $workerIds = array_values(array_filter(array_map('trim', explode(',', (string) ($argv[4] ?? 'worker-1,worker-2')))));
                out($controlPlane->bootstrap($workerJobId, $queues, $workerIds));
            case 'migration:workers:status':
                out($controlPlane->status($workerJobId));
            case 'migration:workers:pause':
                out($controlPlane->pause($workerJobId, (string) ($argv[3] ?? 'operator_request')));
            case 'migration:workers:resume':
                out($controlPlane->resume($workerJobId));
            case 'migration:workers:retry':
                out($controlPlane->retryQueue($workerJobId, (string) ($argv[3] ?? 'stage_1_users')));
            case 'migration:workers:heartbeat':
                $workerId = (string) ($argv[3] ?? 'worker-1');
                $signal = strtolower((string) ($argv[4] ?? 'ok'));
                $statusCode = (int) ($argv[5] ?? 0);
                out($controlPlane->heartbeat($workerJobId, $workerId, $signal !== 'fail', $statusCode));
            default:
                out(['error' => 'Unknown workers command', 'command' => $command], 1);
        }
    }

    $jobId = $argv[3] ?? $storage->createJob($command);

    if ($command === 'migration') {
        $jobController = new JobController($storage->pdo());
        $diffEngine = new DiffEngine();
        $sub = $argv[2] ?? 'help';
        $jobForCommand = $argv[3] ?? $jobId;

        if ($sub === 'audit:source') {
            $deep = in_array('--deep', $argv, true);
            out((new SourceAuditEngine())->run($deep));
        }

        switch ($sub) {
            case 'pause':
                out($jobController->pause($jobForCommand));
            case 'resume':
                out($jobController->resume($jobForCommand));
            case 'retry':
                $entityRef = $argv[4] ?? '';
                [$entityType, $sourceId] = array_pad(explode(':', $entityRef, 2), 2, '');
                out($jobController->retryEntity($jobForCommand, $entityType, $sourceId));
            case 'repair':
                out(['command' => 'migration repair', 'status' => 'queued']);
            case 'diff':
                $entityRef = $argv[4] ?? '';
                [$entityType, $sourceId] = array_pad(explode(':', $entityRef, 2), 2, '');
                out($diffEngine->compare($entityType, $sourceId, ['id' => $sourceId], ['id' => $sourceId]));
            case 'delta:scan':
                $entityFilter = (string) ($argv[4] ?? 'all');
                $phase = 'incremental';
                foreach (array_slice($argv, 4) as $arg) {
                    if (str_starts_with((string) $arg, '--phase=')) {
                        $phase = (string) substr((string) $arg, 8);
                    }
                }
                $allowedPhases = ['initial_bulk', 'incremental', 'pre_cutover', 'final_cutover'];
                if (!in_array($phase, $allowedPhases, true)) {
                    out(['error' => 'Unsupported delta phase', 'phase' => $phase, 'allowed' => $allowedPhases], 1);
                }

                $scanId = 'scan_' . bin2hex(random_bytes(4));
                $now = date(DATE_ATOM);
                $batchSize = max(1, (int) ($config['batch_size'] ?? 100));
                $entityTypes = $entityFilter === 'all' ? $sourceAdapter->entityTypes() : [$entityFilter];
                $summary = ['scan_id' => $scanId, 'phase' => $phase, 'job_id' => $jobForCommand, 'entities' => []];

                foreach ($entityTypes as $entityType) {
                    $existingStateRows = $storage->deltaStates($jobForCommand, $entityType);
                    $existing = [];
                    foreach ($existingStateRows as $row) {
                        $existing[(string) $row['entity_id']] = $row;
                    }

                    $seen = [];
                    $offset = 0;
                    $counts = ['created' => 0, 'updated' => 0, 'deleted' => 0, 'reassigned' => 0];
                    $lastEntityId = null;
                    $latestTs = null;
                    while (true) {
                        $batch = $sourceAdapter->fetch($entityType, $offset, $batchSize);
                        if ($batch === []) {
                            break;
                        }

                        foreach ($batch as $record) {
                            $entityId = (string) ($record['id'] ?? '');
                            if ($entityId === '') {
                                continue;
                            }
                            $seen[$entityId] = true;
                            $lastEntityId = $entityId;
                            $updatedAt = (string) ($record['updated_at'] ?? $record['modified_at'] ?? $now);
                            if ($latestTs === null || strtotime($updatedAt) > strtotime($latestTs)) {
                                $latestTs = $updatedAt;
                            }
                            $ownerKey = (string) ($record['responsible_id'] ?? $record['assigned_to'] ?? $record['owner_id'] ?? $record['user_id'] ?? '');

                            $fingerprintRecord = $record;
                            unset($fingerprintRecord['updated_at'], $fingerprintRecord['modified_at']);
                            $fingerprint = hash('sha256', (string) json_encode($fingerprintRecord, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES));
                            $previous = $existing[$entityId] ?? null;
                            $action = null;
                            if ($previous === null || (int) ($previous['deleted'] ?? 0) === 1) {
                                $action = 'created';
                            } elseif (((string) ($previous['owner_key'] ?? '')) !== $ownerKey) {
                                $action = 'reassigned';
                            } elseif (((string) ($previous['fingerprint'] ?? '')) !== $fingerprint) {
                                $action = 'updated';
                            }

                            if ($action !== null) {
                                $counts[$action]++;
                                $storage->saveDeltaChange($jobForCommand, $scanId, $phase, $entityType, $entityId, $action, $fingerprint, $record);
                            }

                            $storage->upsertDeltaState($jobForCommand, $entityType, $entityId, $fingerprint, $ownerKey, $updatedAt, 0);
                        }

                        $offset += count($batch);
                    }

                    foreach ($existing as $entityId => $prev) {
                        if (!isset($seen[$entityId]) && (int) ($prev['deleted'] ?? 0) === 0) {
                            $counts['deleted']++;
                            $storage->saveDeltaChange($jobForCommand, $scanId, $phase, $entityType, $entityId, 'deleted', (string) ($prev['fingerprint'] ?? ''), ['id' => $entityId]);
                            $storage->upsertDeltaState($jobForCommand, $entityType, $entityId, (string) ($prev['fingerprint'] ?? ''), (string) ($prev['owner_key'] ?? ''), (string) ($prev['updated_at'] ?? $now), 1);
                        }
                    }

                    $watermark = hash('sha256', $jobForCommand . '|' . $entityType . '|' . $scanId . '|' . (string) ($latestTs ?? $now));
                    $storage->saveDeltaCursor($jobForCommand, $entityType, $latestTs ?? $now, $lastEntityId, $watermark, $phase);
                    $summary['entities'][$entityType] = $counts + ['last_entity_id' => $lastEntityId, 'last_sync_timestamp' => $latestTs ?? $now, 'watermark' => $watermark];
                }
                out($summary);
            case 'delta:apply':
                $scanId = $argv[4] ?? null;
                $changes = $storage->pendingDeltaChanges($jobForCommand, is_string($scanId) ? $scanId : null);
                $applied = ['created' => 0, 'updated' => 0, 'deleted' => 0, 'reassigned' => 0];
                $processed = 0;

                foreach ($changes as $change) {
                    $payload = json_decode((string) ($change['payload'] ?? '{}'), true);
                    if (!is_array($payload)) {
                        $payload = [];
                    }

                    $action = (string) ($change['action'] ?? 'updated');
                    $entityType = (string) ($change['entity_type'] ?? '');
                    if (in_array($action, ['created', 'updated', 'reassigned'], true)) {
                        $targetAdapter->upsert($entityType, $payload, false);
                    }

                    $storage->markDeltaChangeApplied((int) $change['id']);
                    $applied[$action] = ($applied[$action] ?? 0) + 1;
                    $processed++;
                }

                out(['job_id' => $jobForCommand, 'scan_id' => $scanId, 'processed' => $processed, 'applied' => $applied, 'idempotent' => true]);
            case 'delta:status':
                out(['job_id' => $jobForCommand] + $storage->deltaStatus($jobForCommand));
            default:
                out(['error' => 'Unknown migration subcommand', 'subcommand' => $sub], 1);
        }
    }

    switch ($command) {
        case 'plan':
            out($runtime->plan($jobId));
        case 'dry-run':
            out($runtime->dryRun($jobId));
        case 'execute':
            out($runtime->execute($jobId, false));
        case 'pause':
            $storage->setJobStatus($jobId, 'paused');
            out(['job_id' => $jobId, 'status' => 'paused']);
        case 'resume':
            out($runtime->execute($jobId, true));
        case 'verify':
        case 'verify-only':
            out($runtime->verify($jobId));
        case 'report':
        case 'status':
            out(['job_id' => $jobId, 'summary' => $storage->summary($jobId)]);
        case 'system:check':
            $client = null;
            if ((($_ENV['BITRIX_WEBHOOK_URL'] ?? '') !== '') && (($_ENV['BITRIX_WEBHOOK_TOKEN'] ?? '') !== '')) {
                $client = new BitrixRestClient((string) $_ENV['BITRIX_WEBHOOK_URL'], (string) $_ENV['BITRIX_WEBHOOK_TOKEN']);
            }
            out((new SystemCheckService($client))->check($storagePath));
        case 'migration:hypercare:start':
            out(['command' => $command, 'status' => 'started', 'windows' => ['15 minutes', '1 hour', '6 hours', '24 hours', '3 days', '7 days', '30 days']]);
        case 'migration:hypercare:scan':
            out(['command' => $command, 'status' => 'completed', 'integrity_scan' => ['issues' => 0, 'integrity_score' => 1.0]]);
        case 'migration:hypercare:reconcile':
            out(['command' => $command, 'status' => 'completed', 'reconciliation' => ['resolved' => 0, 'queued_manual' => 0]]);
        case 'migration:hypercare:report':
            out(['command' => $command, 'status' => 'generated', 'formats' => ['pdf', 'json', 'html', 'docx']]);
        case 'migration:hypercare:archive':
            out(['command' => $command, 'status' => 'archived', 'scope' => ['migration plans', 'entity maps', 'logs', 'diff reports', 'integrity scans', 'cutover events', 'runbooks']]);
        default:
            out(['error' => 'Unknown command', 'command' => $command], 1);
    }
} catch (Throwable $e) {
    out(['error' => $e->getMessage(), 'hint' => 'Prototype mode: run "php bin/migration-module validate" first.'], 1);
}
