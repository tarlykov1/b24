#!/usr/bin/env php
<?php

declare(strict_types=1);

use MigrationModule\Application\Checkpoint\CheckpointService;
use MigrationModule\Application\Config\ProductionConfigService;
use MigrationModule\Application\Cutover\CutoverService;
use MigrationModule\Application\Freeze\FreezeModeService;
use MigrationModule\Application\Monitoring\MonitoringDashboardService;
use MigrationModule\Application\Plan\DryRunService;
use MigrationModule\Application\Plan\MigrationPlanningService;
use MigrationModule\Application\Readiness\ProductionReadinessChecklistService;
use MigrationModule\Application\Reconciliation\PostMigrationReconciliationService;
use MigrationModule\Application\Report\FinalReportService;
use MigrationModule\Application\Rollback\RollbackService;
use MigrationModule\Application\Sync\DeltaSyncService;
use MigrationModule\Cli\MigrationCommands;
use MigrationModule\Infrastructure\Persistence\MigrationRepository;

$autoload = __DIR__ . '/../vendor/autoload.php';
if (is_file($autoload)) {
    require_once $autoload;
} else {
    spl_autoload_register(static function (string $class): void {
        $prefix = 'MigrationModule\\';
        if (!str_starts_with($class, $prefix)) {
            return;
        }

        $relative = substr($class, strlen($prefix));
        $path = __DIR__ . '/../apps/migration-module/src/' . str_replace('\\', '/', $relative) . '.php';
        if (is_file($path)) {
            require_once $path;
        }
    });
}

$repo = new MigrationRepository();
$commands = new MigrationCommands(
    $repo,
    new DryRunService(new MigrationPlanningService($repo)),
    new MigrationPlanningService($repo),
    new PostMigrationReconciliationService($repo),
    new DeltaSyncService($repo),
    new FinalReportService(),
    new CutoverService($repo, new DeltaSyncService($repo), new FreezeModeService()),
    new RollbackService($repo),
    new CheckpointService(),
    new ProductionConfigService(),
    new MonitoringDashboardService(),
    new ProductionReadinessChecklistService(),
);

$command = $argv[1] ?? '';

switch ($command) {
    case 'migration':
        $action = $argv[2] ?? 'status';
        $jobId = $argv[3] ?? $commands->createJob('cli_default');

        switch ($action) {
            case 'start':
            case 'pause':
            case 'resume':
                echo json_encode(['action' => $action, 'status' => 'accepted', 'job_id' => $jobId], JSON_PRETTY_PRINT) . PHP_EOL;
                break;
            case 'status':
                echo json_encode($commands->status($jobId), JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . PHP_EOL;
                break;
            case 'verify':
                echo json_encode(['stage' => 'verification', 'status' => 'ready', 'job_id' => $jobId], JSON_PRETTY_PRINT) . PHP_EOL;
                break;
            case 'dry-run':
                echo json_encode($commands->dryRun($jobId, ['users' => [['id' => '1']]], ['users' => []]), JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . PHP_EOL;
                break;
            case 'delta-sync':
                echo json_encode($commands->deltaSyncPreview($jobId, 'users', [['id' => '1', 'updated_at' => date(DATE_ATOM)]], []), JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . PHP_EOL;
                break;
            case 'cutover':
                echo json_encode(
                    $commands->cutover($jobId, 'users', ['main_transfer_done' => true, 'critical_errors' => 0], [['id' => '1', 'updated_at' => date(DATE_ATOM)]], [], true, true),
                    JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE,
                ) . PHP_EOL;
                break;
            case 'rollback':
                echo json_encode($commands->rollback($jobId, 'operator_cancelled', 'cutover', $argv[4] ?? 'safe'), JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . PHP_EOL;
                break;
            case 'report':
                echo json_encode(['written' => $commands->exportReports([])], JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . PHP_EOL;
                break;
            default:
                echo "Unknown migration action\n";
                exit(1);
        }
        break;
    default:
        echo "Usage: migration-module migration [start|pause|resume|status|verify|dry-run|delta-sync|cutover|rollback|report] [jobId]\n";
        exit(1);
}
